# ---------------------------------------------------------------------------
# ConstructionPlanner environment variables
# Copy to .env for local dev, or set these in your deployment platform.
# ---------------------------------------------------------------------------

# PostgreSQL connection string (REQUIRED in production; the app throws on boot
# if NODE_ENV=production and this is unset). In dev it falls back to a local
# default. The schema is created automatically on first boot (ensureSchema).
DATABASE_URL=postgresql://appuser:apppass@localhost:5432/constructionplanner

# Session signing secret (REQUIRED in production, must be >= 16 chars).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# HTTP port the server binds (default 5000).
PORT=5000

# Set to "production" in prod. Enables secure cookies and strict env checks.
NODE_ENV=development

# ----- Email (optional) -----------------------------------------------------
# If SMTP_HOST is unset, notification emails are written to
# data/email-outbox.log instead of being sent (rotated at 5 MB).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@constructionplanner.local
